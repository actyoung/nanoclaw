# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - runtime directories, templates are in .templates/groups/
# First ignore all groups, then unignore specific files
/groups/*
!/groups/main/
!/groups/global/
/groups/main/*
!/groups/main/.gitkeep
!/groups/main/CLAUDE.md
/groups/global/*
!/groups/global/.gitkeep
!/groups/global/CLAUDE.md
!/groups/.gitkeep

# Secrets
*.keys.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
